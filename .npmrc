# pnpm settings for the monorepo
# Hoist shared deps to the root to avoid phantom duplicates across packages
hoist-pattern[]=*
# Keep @types and eslint out of the root hoist to avoid version conflicts
hoist-pattern[]=!@types/*
hoist-pattern[]=!eslint*
# Strict peer-dependency resolution (default in pnpm 9, but explicit is clearer)
strict-peer-dependencies=false
# Speed up installs with a content-addressable store
shamefully-hoist=false
