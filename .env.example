EMAIL_FROM=noreply@nexusanime.com

# ── Stripe (S5) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Cloudflare (S6) ────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
R2_ACCESS_KEY_ID=
