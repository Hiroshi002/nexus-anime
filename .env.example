# ── Application ──────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (S2 — include placeholder in M1) ────────────
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus_anime

# ── Auth (S4 — include placeholder in M1) ────────────────
AUTH_SECRET=
