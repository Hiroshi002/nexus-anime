{
  "name": "@nexus/cache",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./keys": "./src/keys.ts",
    "./ttl": "./src/ttl.ts",
    "./rate-limit": "./src/rate-limit.ts",
    "./invalidation": "./src/invalidation.ts",
    "./feature-flags": "./src/feature-flags.ts",
    "./domains/*": "./src/domains/*"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0",
    "@upstash/ratelimit": "^2.0.0"
  },
  "devDependencies": {
    "@nexus/config-typescript": "workspace:*",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
